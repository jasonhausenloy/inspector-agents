# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Ephemeral state (resume files, run logs) — NOT published
*.log
logs/scenarios/*.state.json
logs/scenarios/*.run.log

# Everything else (JSONL traces, verdict JSONs, system fingerprints)
# IS published — auditable artifacts of every claim on the page.
