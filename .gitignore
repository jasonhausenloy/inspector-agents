# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
gpu-runs/.env

# gpu-runs scratch (large, host-specific; pushed to HF Datasets, not git)
gpu-runs/output/
gpu-runs/output_smoke/
